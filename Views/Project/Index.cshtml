@model IEnumerable<ProjectManagement.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-kanban-fill text-primary"></i>
            My Projects
        </h2>

        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createProjectModal">
            <i class="bi bi-plus-lg"></i>
            New Project
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <input class="form-control" placeholder="Search projects..." />
        </div>

        <div class="col-md-3">
            <select class="form-select">
                <option>All Status</option>
                <option>Not Started</option>
                <option>In Progress</option>
                <option>Completed</option>
                <option>On Hold</option>
            </select>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">

            <div class="card-body text-center py-5">

                <i class="bi bi-folder2-open display-1 text-secondary"></i>

                <h4 class="mt-3">
                    No projects yet
                </h4>

                <p class="text-muted">
                    Create your first project to get started.
                </p>

                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createProjectModal">
                    <i class="bi bi-plus-lg"></i>
                    Create Project
                </button>
            </div>

        </div>
    }
    else
    {
        <div class="row">

            @foreach (Project project in Model)
            {
                <div class="col-lg-4 mb-4">

                    <div class="card shadow-sm h-100 border-0">

                        <div class="card-body">

                            <div class="d-flex justify-content-between">

                                <h5 class="fw-bold">
                                    @project.Name
                                </h5>

                                @switch (project.Status)
                                {
                                    case ProjectStatus.NotStarted:
                                        <span class="badge bg-secondary">
                                            Not Started
                                        </span>
                                        break;

                                    case ProjectStatus.InProgress:
                                        <span class="badge bg-warning text-dark">
                                            In Progress
                                        </span>
                                        break;

                                    case ProjectStatus.Completed:
                                        <span class="badge bg-success">
                                            Completed
                                        </span>
                                        break;

                                    default:
                                        <span class="badge bg-info">
                                            On Hold
                                        </span>
                                        break;
                                }

                            </div>

                            <p class="text-muted mt-3">
                                @project.Description
                            </p>

                            <hr>

                            <div class="small text-muted">

                                <div>
                                    <i class="bi bi-calendar-event"></i>
                                    Created:
                                    @project.CreatedAt.ToShortDateString()
                                </div>

                                @if (project.DueDate.HasValue)
                                {
                                    <div class="mt-2">
                                        <i class="bi bi-clock"></i>
                                        Due:
                                        @project.DueDate.Value.ToShortDateString()
                                    </div>
                                }

                            </div>

                        </div>

                        <div class="card-footer bg-white">

                            <div class="d-flex gap-2">

                                <a asp-action="Details" asp-route-id="@project.Id"
                                   class="btn btn-outline-primary btn-sm flex-fill">
                                    View
                                </a>

                                <a asp-action="Edit" asp-route-id="@project.Id"
                                   class="btn btn-outline-warning btn-sm flex-fill">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@project.Id"
                                   class="btn btn-outline-danger btn-sm flex-fill">
                                    Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>








<!-- Create Project Modal -->
<div class="modal fade" id="createProjectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-kanban"></i>
                    Create Project
                </h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal">
                </button>

            </div>

            <form asp-action="Create" method="post">

                <div class="modal-body">

                    <div class="mb-3">

                        <label class="form-label">
                            Project Name
                        </label>

                        <input class="form-control" name="Name" maxlength="30" required />

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Description
                        </label>

                        <textarea class="form-control" name="Description" rows="4" maxlength="500"></textarea>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Due Date
                        </label>

                        <input type="date" class="form-control" name="DueDate" />

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>


                    <button type="submit" class="btn btn-primary">
                        Create
                    </button>

                </div>
            </form>
        </div>
    </div>
</div>